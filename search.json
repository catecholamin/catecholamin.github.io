---
layout: null
---

[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | json_encode }},
      "tags"     : "{% for tag in post.tags %}{% if forloop.rindex != 1 %}{{ tag }} {% else %}{{ tag }}{% endif %}{% endfor %}",
      "url"      : {{ post.url | json_encode }},
      "date"     : {{ post.date | json_encode }},
      "excerpt"  : {{ post.content | strip_html | strip_newlines | truncate: 200 | json_encode }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
